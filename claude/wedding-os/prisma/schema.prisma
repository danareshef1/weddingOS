generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COUPLE
  ADMIN
  GUEST
  VENDOR
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  DECLINED
  MAYBE
}

enum Channel {
  SMS
  EMAIL
  WHATSAPP
}

enum TableShape {
  ROUND
  SQUARE
  RECTANGLE
}

model Wedding {
  id                 String   @id @default(cuid())
  slug               String   @unique
  partner1Name       String
  partner2Name       String
  date               DateTime?
  venue              String?
  locale             String   @default("he")
  theme              String   @default("default")
  onboardingComplete Boolean  @default(false)
  venuePricePerPerson  Float  @default(0)
  venueMinGuests       Int    @default(0)
  venueReservePrice    Float  @default(0)
  venueExtraHourPrice  Float  @default(0)
  venueExtraPersons    Int    @default(0)
  venueExtraHours      Int    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users            User[]
  inviteCodes      InviteCode[]
  guests           Guest[]
  tables           Table[]
  budgetItems      BudgetItem[]
  vendors          Vendor[]
  galleryImages    GalleryImage[]
  documents        Document[]
  todoItems        TodoItem[]
  messageTemplates MessageTemplate[]
  messageSends     MessageSend[]
  faqs             FAQ[]
  timelineEvents   TimelineEvent[]
  scheduleItems    ScheduleItem[]
  forecastBoards    ForecastBoard[]
  seatingBackground String?
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          Role      @default(GUEST)
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  weddingId     String?
  wedding       Wedding?  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]

  @@index([weddingId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  weddingId String
  wedding   Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guestId   String?
  maxUses   Int       @default(1)
  uses      Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([weddingId])
}

model Guest {
  id          String     @id @default(cuid())
  weddingId   String
  wedding     Wedding    @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  email       String?
  phone       String?
  group       String?
  tags        String[]   @default([])
  tableId     String?
  table       Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  rsvpStatus  RsvpStatus @default(PENDING)
  mealChoice  String?
  allergies   String?
  plusOneName  String?
  plusOneMeal  String?
  songRequest String?
  inviteCode    String?
  rsvpToken     String?   @unique
  respondedAt   DateTime?
  messageSentAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messageLogs MessageLog[]

  @@index([weddingId])
  @@index([tableId])
}

model Table {
  id        String     @id @default(cuid())
  weddingId String
  wedding   Wedding    @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String
  shape     TableShape @default(ROUND)
  capacity  Int        @default(10)
  x         Float      @default(0)
  y         Float      @default(0)

  guests Guest[]

  @@index([weddingId])
}

model BudgetItem {
  id            String   @id @default(cuid())
  weddingId     String
  wedding       Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  category      String
  vendor        String?
  description   String?
  estimated     Float    @default(0)
  actual        Float    @default(0)
  paid          Float    @default(0)
  deposit       Float    @default(0)
  paymentMethod String?
  dueDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([weddingId])
}

model Vendor {
  id               String    @id @default(cuid())
  weddingId        String
  wedding          Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name             String
  category         String
  phone            String?
  email            String?
  notes            String?
  status           String    @default("NOT_STARTED")
  isDefault        Boolean   @default(false)
  amountPaid       Float     @default(0)
  remainingBalance Float     @default(0)
  paymentDate      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([weddingId])
}

model GalleryImage {
  id           String  @id @default(cuid())
  weddingId    String
  wedding      Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  url          String
  thumbnailUrl String?
  uploadedBy   String?
  approved     Boolean @default(false)
  public       Boolean @default(true)
  caption      String?
  createdAt    DateTime @default(now())

  @@index([weddingId])
}

model MessageTemplate {
  id        String  @id @default(cuid())
  weddingId String
  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String
  subject   String?
  body      String
  channel   Channel @default(EMAIL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
}

model FAQ {
  id         String  @id @default(cuid())
  weddingId  String
  wedding    Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  questionHe String
  answerHe   String
  questionEn String?
  answerEn   String?
  order      Int     @default(0)

  @@index([weddingId])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title       String
  description String?
  date        DateTime
  iconType    String?
  order       Int      @default(0)

  @@index([weddingId])
}

model Document {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String
  url       String
  fileType  String
  size      Int
  category  String   @default("other")
  notes     String?
  createdAt DateTime @default(now())

  @@index([weddingId])
}

model TodoItem {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title     String
  status    String   @default("todo")
  createdAt DateTime @default(now())

  @@index([weddingId])
}

model ScheduleItem {
  id          String  @id @default(cuid())
  weddingId   String
  wedding     Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  time        String
  title       String
  description String?
  order       Int     @default(0)

  @@index([weddingId])
}

model ForecastBoard {
  id        String         @id @default(cuid())
  weddingId String
  wedding   Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  items     ForecastItem[]

  @@index([weddingId])
}

model ForecastItem {
  id            String        @id @default(cuid())
  boardId       String
  board         ForecastBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name          String
  isVenue       Boolean       @default(false)
  cost          Float         @default(0)
  pricePerGuest Float         @default(0)
  numGuests     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([boardId])
}

model MessageSend {
  id             String       @id @default(cuid())
  weddingId      String
  wedding        Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  body           String       @db.Text
  channel        Channel
  recipientCount Int
  sentAt         DateTime     @default(now())
  logs           MessageLog[]

  @@index([weddingId])
}

model MessageLog {
  id            String      @id @default(cuid())
  messageSendId String
  messageSend   MessageSend @relation(fields: [messageSendId], references: [id], onDelete: Cascade)
  guestId       String
  guest         Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  status        String      @default("sent")
  error         String?
  sentAt        DateTime    @default(now())

  @@index([messageSendId])
  @@index([guestId])
}
